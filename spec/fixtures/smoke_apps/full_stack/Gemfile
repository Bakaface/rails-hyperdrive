source "https://rubygems.org"

rails_version = ENV["RAILS_VERSION"]
if rails_version && !rails_version.empty?
  gem "rails", "~> #{rails_version}.0"
else
  gem "rails", ">= 7.2", "< 8.1"
end

gem "sqlite3", "~> 2.0"
gem "puma", "~> 6.0"

# Present purely so StackProfile picks them up in Gemfile.lock and the
# install generator's CLAUDE.md / .mcp.json reflect a realistic stack.
# `require: false` keeps boot lean — these gems are never actually wired in.
gem "devise", require: false
gem "sidekiq", require: false
gem "pundit", require: false
